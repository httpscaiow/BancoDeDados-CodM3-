-- Inserindo dados na tabela Entrega
INSERT INTO Entrega (nome_destinatario, endereco_destinatario, telefone_destinatario, total_compra, status, data_pedido_gerado, data_pedido_entregue, funcionario_responsavel, unidade_responsavel) VALUES
('João da Silva', 'Av. Central, 789', '11777777777', 100.00, 'não entregue', '2025-07-01 10:30:00', NULL, 1, 1),
('Ana Paula', 'Rua D, 321', '11666666666', 150.00, 'separação', '2025-07-01 11:35:00', NULL, 2, 2);

-- Inserindo dados na tabela Medicamento_Entrega
INSERT INTO Medicamento_Entrega (codigo_medicamento, codigo_entrega, quantidade) VALUES
(1, 1, 2),
(2, 1, 1),
(1, 2, 3);</sql><current_tab id="0"/></tab_sql></sqlb_project>
