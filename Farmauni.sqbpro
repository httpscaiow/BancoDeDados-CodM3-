CREATE TABLE Unidade ( 
    codigo_unidade INTEGER PRIMARY KEY AUTOINCREMENT, 
    endereco TEXT, 
    cep TEXT 
);

-- Criação da tabela Funcionario
CREATE TABLE Funcionario (
    codigo_funcionario INTEGER PRIMARY KEY AUTOINCREMENT,
    nome TEXT,
    cargo TEXT,
    salario REAL,
    cpf TEXT UNIQUE,
    email_interno TEXT UNIQUE,
    numero_telefone TEXT UNIQUE,
    data_nascimento TEXT,
    unidade_de_trabalho INTEGER,
    FOREIGN KEY (unidade_de_trabalho) REFERENCES Unidade(codigo_unidade)
);

-- Criação da tabela Medicamento
CREATE TABLE Medicamento (
    codigo_medicamento INTEGER PRIMARY KEY AUTOINCREMENT,
    nome TEXT,
    descricao TEXT,
    laboratorio TEXT,
    preco REAL,
    qtde_estoque INTEGER
);

-- Criação da tabela Entrega
CREATE TABLE Entrega (
    codigo_entrega INTEGER PRIMARY KEY AUTOINCREMENT,
    nome_destinatario TEXT,
    endereco_destinatario TEXT,
    telefone_destinatario TEXT,
    total_compra REAL,
    funcionario_responsavel INTEGER,
    unidade_responsavel INTEGER,
    status TEXT NOT NULL, -- feita, não feita, em tentativa, separação, não entregue
    data_pedido_gerado TEXT NOT NULL,
    data_pedido_entregue TEXT, 
    FOREIGN KEY (funcionario_responsavel) REFERENCES Funcionario(codigo_funcionario),
    FOREIGN KEY (unidade_responsavel) REFERENCES Unidade(codigo_unidade)
);

-- Criação da tabela Medicamento_Entrega
CREATE TABLE Medicamento_Entrega (
    codigo_medicamento INTEGER,
    codigo_entrega INTEGER,
    quantidade INTEGER,
    PRIMARY KEY (codigo_medicamento, codigo_entrega),
    FOREIGN KEY (codigo_medicamento) REFERENCES Medicamento(codigo_medicamento),
    FOREIGN KEY (codigo_entrega) REFERENCES Entrega(codigo_entrega)
);

-- Inserindo dados na tabela Unidade
INSERT INTO Unidade (endereco, cep) VALUES
('Rua A, 123', '12345-000'),
('Rua B, 456', '54321-000');

-- Inserindo dados na tabela Funcionario
INSERT INTO Funcionario (nome, cargo, salario, cpf, email_interno, numero_telefone, data_nascimento, unidade_de_trabalho) VALUES
